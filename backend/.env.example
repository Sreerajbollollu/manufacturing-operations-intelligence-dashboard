# FactoryPulse AI - Backend Environment Variables
# Copy to .env and fill in values before running.

# Supabase direct DB connection via Transaction Pooler (port 6543).
# Keep real credentials in backend/.env only.
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
